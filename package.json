{
  "name": "cordova-plugin-android-debug-ssl-bypass-disable",
  "version": "1.0.0",
  "description": "A Cordova plugin to disable the default SSL error bypass in Android debug builds",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write package.json README.md plugin.xml",
    "format:check": "prettier --check package.json README.md plugin.xml",
    "test:unit": "echo \"No unit tests yet\"",
    "test": "npm run format:check && npm run test:unit"
  },
  "keywords": [
    "cordova",
    "ecosystem:cordova",
    "cordova-android"
  ],
  "author": "VoltBuilder",
  "license": "Apache-2.0",
  "type": "commonjs",
  "cordova": {
    "id": "cordova-plugin-android-debug-ssl-bypass-disable",
    "platforms": [
      "android"
    ]
  },
  "engines": {
    "cordovaDependencies": {
      "1.0.0": {
        "cordova-android": ">=4.0.0"
      }
    }
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "prettier": "^3.8.4"
  },
  "repository": "github:voltbuilder/cordova-plugin-android-debug-ssl-bypass-disable",
  "bugs": "https://github.com/voltbuilder/cordova-plugin-android-debug-ssl-bypass-disable/issues",
  "homepage": "https://volt.build/"
}
